<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white_4">

    <ImageView
        android:id="@+id/status_bar"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_alignParentTop="true"
        android:background="@drawable/status_bar">
    </ImageView>

    <RelativeLayout
        android:id="@+id/search_bar"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_below="@id/status_bar">

        <RelativeLayout
            android:id="@+id/search_in"
            android:layout_width="0dp"
            android:layout_height="35dp"
            android:layout_alignParentStart="true"
            android:layout_toStartOf="@+id/clear_text"
            android:layout_marginStart="10dp"
            android:layout_marginEnd="10dp"
            android:layout_centerVertical="true"
            android:background="@drawable/circle_white">

            <ImageView
                android:id="@+id/search_icon2"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_centerVertical="true"
                android:layout_marginStart="10dp"
                android:background="@drawable/search">
            </ImageView>

            <EditText
                android:id="@+id/search_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_toEndOf="@id/search_icon2"
                android:layout_toStartOf="@+id/close_button"
                android:layout_marginStart="5dp"
                android:hint="Search"
                android:textSize="14sp"
                android:textColor="@color/brown"
                android:layout_centerVertical="true">
            </EditText>
            <RelativeLayout
                android:id="@+id/close_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                >

            <de.hdodenhof.circleimageview.CircleImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_centerInParent="true"
                android:layout_marginEnd="5dp"
                android:src="@color/light_grey">
            </de.hdodenhof.circleimageview.CircleImageView>
                <ImageView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/close"
                    android:layout_centerInParent="true"
                    >
                </ImageView>
            </RelativeLayout>

        </RelativeLayout>

        <TextView
            android:id="@+id/clear_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:text="@string/clear"
            android:textSize="16sp"
            android:textColor="@color/red"
            android:layout_marginEnd="10dp">
        </TextView>
    </RelativeLayout>

    <LinearLayout
        android:id="@+id/tabs_row"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:layout_below="@id/search_bar"
        android:orientation="horizontal"
        android:gravity="center">

        <TextView
            android:id="@+id/tab_all"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="All"
            android:textColor="@color/black"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tab_followers"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Followers"
            android:textColor="@color/light_grey"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tab_following"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Following"
            android:textColor="@color/light_grey"
            android:textStyle="bold" />
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/results_recyclerview"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/tabs_row"
        android:layout_above="@id/home_indicator" />

    <ImageView
        android:id="@+id/home_indicator"
        android:layout_width="match_parent"
        android:layout_height="20dp"
        android:layout_alignParentBottom="true"
        android:background="@drawable/home_indicator" >
    </ImageView>

</RelativeLayout>
