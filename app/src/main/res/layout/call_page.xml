<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#101010"
    tools:context=".TenthActivity">

    <!-- Container for remote video -->
    <FrameLayout
        android:id="@+id/remote_video_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />


    <FrameLayout
        android:id="@+id/local_video_view"
        android:layout_width="120dp"
        android:layout_height="160dp"
        android:layout_alignParentEnd="true"
        android:layout_margin="16dp"
        android:elevation="8dp"
        android:background="@drawable/box3_black"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/audio_layout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:orientation="vertical"
        android:gravity="center">

        <ImageView
            android:id="@+id/caller_photo"
            android:layout_width="150dp"
            android:layout_height="150dp"
            android:src="@drawable/profile_image"
            android:scaleType="centerCrop"
            android:adjustViewBounds="true"
            android:background="@drawable/circle" />

        <TextView
            android:id="@+id/caller_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Mom"
            android:textColor="@android:color/white"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="00:25"
            android:textColor="#B0B0B0"
            android:textSize="16sp"
            android:layout_marginTop="6dp" />
    </LinearLayout>


    <LinearLayout
        android:id="@+id/call_controls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:gravity="center"
        android:layout_marginBottom="40dp">

        <ImageView
            android:id="@+id/sound"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:src="@drawable/sound_on"
            android:layout_marginEnd="60dp" />

        <ImageView
            android:id="@+id/decline"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@drawable/end_call_icon" />

        <ImageView
            android:id="@+id/options_5"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_marginStart="60dp"
            android:src="@drawable/menu" />
    </LinearLayout>

</RelativeLayout>
