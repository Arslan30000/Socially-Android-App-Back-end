<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black">

    <!-- Container for the remote user's video. This is where the other person's video will appear. -->
    <FrameLayout
        android:id="@+id/remote_video_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Container for the local user's video. This is your video feed. -->
    <FrameLayout
        android:id="@+id/local_video_container"
        android:layout_width="120dp"
        android:layout_height="160dp"
        android:layout_alignParentTop="true"
        android:layout_alignParentEnd="true"
        android:layout_marginTop="24dp"
        android:layout_marginEnd="24dp"
        android:background="@android:color/darker_gray" />

    <!-- Container for call control buttons -->
    <LinearLayout
        android:id="@+id/call_controls_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="48dp"
        android:gravity="center"
        android:orientation="horizontal">

        <!-- Mute Button -->
        <ImageButton
            android:id="@+id/mute_button"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_marginHorizontal="15dp"
            android:contentDescription="Mute"
                android:background="@drawable/music"/>

        <!-- End Call Button -->
        <ImageButton
            android:id="@+id/end_call_button"
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:layout_marginHorizontal="15dp"
            android:contentDescription="End Call"
                android:background="@drawable/ic_decline_call"/>

        <!-- Switch Camera Button -->
        <ImageButton
            android:id="@+id/switch_camera_button"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_marginHorizontal="15dp"
            android:contentDescription="Switch Camere"
                android:background="@drawable/camera"/>

            
        <!-- Disable Video Button -->
        <ImageButton
            android:id="@+id/disable_video_button"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_marginHorizontal="15dp"
            android:contentDescription="Disable Video"
                android:background="@drawable/info"/>

    </LinearLayout>

</RelativeLayout>
